{
  "name": "visgraph",
  "description": "Browser-based interactive RDF/ontology knowledge graph editor — authoring, OWL-RL reasoning, clustering, multi-algorithm layout, and MCP support. Runs entirely client-side.",
  "version": "1.1.0",
  "license": "Apache-2.0",
  "author": "Thomas Hanke <thomas.hnke82@gmail.com> (https://github.com/ThHanke)",
  "homepage": "https://thhanke.github.io/visgraph/",
  "repository": {
    "type": "git",
    "url": "https://github.com/ThHanke/visgraph.git"
  },
  "keywords": [
    "rdf",
    "ontology",
    "knowledge-graph",
    "sparql",
    "owl",
    "reasoning",
    "visualization",
    "linked-data",
    "semantic-web",
    "turtle",
    "json-ld",
    "graph-editor",
    "fair-data",
    "reactodia",
    "mcp"
  ],
  "private": false,
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "stop": "node server.stop.js",
    "dev": "VITE_VG_DEBUG=true vite",
    "dev:https": "VITE_VG_DEBUG=true vite",
    "prebuild": "node scripts/generate-mcp-json.mjs",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "lint": "eslint .",
    "preview": "vite preview",
    "postinstall": "patch-package",
    "test": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:real": "playwright test e2e/relay-bookmarklet.real.spec.ts",
    "generate:mcp": "node scripts/generate-mcp-json.mjs",
    "demo": "node scripts/run-demo.mjs",
    "callgraph:generate": "node scripts/generate_call_graph_ts_morph.js",
    "callgraph:merge": "node scripts/merge_call_graphs.js",
    "callgraph:regen": "npm run callgraph:generate && npm run callgraph:merge",
    "startupDebug": "node scripts/playwright-startup-debug.cjs",
    "startupDebug:start": "node scripts/playwright-startup-debug.cjs --start-server"
  },
  "overrides": {
    "esbuild": "0.25.0"
  },
  "dependencies": {
    "@comunica/query-sparql-rdfjs": "^5.2.1",
    "@radix-ui/react-accordion": "1.2.12",
    "@radix-ui/react-alert-dialog": "1.1.15",
