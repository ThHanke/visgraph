    "tailwind-merge": "3.3.1",
    "vaul": "1.1.2",
    "zustand": "5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.1.16",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react-swc": "^4.2.0",
    "eslint": "^9.39.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^27.1.0",
    "patch-package": "^8.0.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.3",
    "vite": "^7.1.12",
    "vitest": "^4.0.6"
  },
  "vitest": {
    "environment": "jsdom",
    "setupFiles": [
      "src/test-setup.ts"
    ]
  }
}
