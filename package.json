    "ngraph.slpa": "0.1.0",
    "rdf-parse": "4.0.0",
    "rdf-validate-shacl": "^0.6.5",
    "react": "19.2.0",
    "react-day-picker": "9.11.1",
    "react-dom": "19.2.0",
    "react-resizable-panels": "3.0.6",
    "react-router-dom": "7.14.1",
    "readable-stream": "4.7.0",
    "recharts": "3.3.0",
    "socket.io": "4.8.3",
    "socket.io-client": "4.8.3",
